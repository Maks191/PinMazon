# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6-luna
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=low

# ---------- Pinterest ----------
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:8787/callback
PINTEREST_TOKEN_FILE=data/pinterest_token.json
PINTEREST_DEFAULT_BOARD_ID=

# ---------- Amazon ----------
# Prefer a valid SiteStripe/Special Link. This tracking ID is only used
# to construct a clean /dp/ASIN link when you paste a normal amazon.com URL.
AMAZON_TRACKING_ID=
AMAZON_MARKETPLACE_HOST=www.amazon.com

# ---------- App ----------
BRAND_NAME=SMART GEAR LAB
DEFAULT_PUBLISH_MODE=generate_only
ALLOW_UNTAGGED_AMAZON_LINKS=false
ALLOWED_DESTINATION_DOMAINS=amazon.com,www.amazon.com,amzn.to
HISTORY_FILE=data/history.jsonl
OUTPUT_DIR=output
