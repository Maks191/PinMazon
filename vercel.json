{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "fastapi",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    }
  ],
  "functions": {
    "app.py": {
      "maxDuration": 300,
      "memory": 1024
    }
  }
}
